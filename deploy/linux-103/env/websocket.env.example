# ===== 103 websocket 环境变量模板 =====
# 复制为 websocket.env 后填入实际值

ENVIRONMENT=production
LOG_LEVEL=INFO

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=<TIDB_USER>
MYSQL_PASSWORD=<TIDB_PASSWORD>
MYSQL_DATABASE=xianyu_data

REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=<UPSTASH_PASSWORD>
REDIS_DB=0

JWT_SECRET_KEY=<SHARED_JWT_SECRET>
JWT_ALGORITHM=HS256

# 服务端口
WEBSOCKET_PORT=8090

# 浏览器配置（103 无 Chromium，保留变量避免初始化报错）
MAX_CAPTCHA_CONCURRENT=1
BROWSER_HEADLESS=true

# Token 刷新配置（秒）
TOKEN_REFRESH_INTERVAL=72000
TOKEN_RETRY_INTERVAL=7200

# 服务间通信
BACKEND_WEB_SERVICE_URL=http://127.0.0.1:8089

# 静态文件
STATIC_DIR=/app/static
