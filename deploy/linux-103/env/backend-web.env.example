# ===== 103 backend-web 环境变量模板 =====
# 复制为 backend-web.env 后填入实际值。切勿提交到仓库。

ENVIRONMENT=production
LOG_LEVEL=INFO

# --- MySQL（通过本机 stunnel 桥接到 TiDB Cloud） ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=<TIDB_USER>
MYSQL_PASSWORD=<TIDB_PASSWORD>
MYSQL_DATABASE=xianyu_data

# --- Redis（通过本机 stunnel 桥接到 Upstash） ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=<UPSTASH_PASSWORD>
REDIS_DB=0

# --- JWT（103 与 27 必须完全一致） ---
JWT_SECRET_KEY=<SHARED_JWT_SECRET>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- 服务端口与互联 ---
BACKEND_WEB_PORT=8089
WEBSOCKET_SERVICE_URL=http://127.0.0.1:8090
SCHEDULER_SERVICE_URL=http://127.0.0.1:8091

# --- 业务开关 ---
# 103 不执行 Chromium 相关任务，自动爬虫必须关闭
AUTO_START_CRAWL_JOBS=false

# --- CORS（如需外网访问，限制具体域名） ---
CORS_ORIGINS=*

# --- 静态资源 ---
STATIC_DIR=/app/static
FRONTEND_PUBLIC_URL=http://192.168.1.103:9000
BACKEND_WEB_PUBLIC_URL=http://192.168.1.103:9000
