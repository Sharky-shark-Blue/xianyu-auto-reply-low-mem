# ===== 103 scheduler 环境变量模板 =====
# 复制为 scheduler.env 后填入实际值

ENVIRONMENT=production
LOG_LEVEL=INFO

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=<TIDB_USER>
MYSQL_PASSWORD=<TIDB_PASSWORD>
MYSQL_DATABASE=xianyu_data

REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=<UPSTASH_PASSWORD>
REDIS_DB=0

JWT_SECRET_KEY=<SHARED_JWT_SECRET>
JWT_ALGORITHM=HS256

SCHEDULER_PORT=8091

# 任务配置（秒）
REDELIVERY_INTERVAL=5
RATE_INTERVAL=20

# 服务间通信
WEBSOCKET_SERVICE_URL=http://127.0.0.1:8090
BACKEND_WEB_SERVICE_URL=http://127.0.0.1:8089

STATIC_DIR=/app/static
