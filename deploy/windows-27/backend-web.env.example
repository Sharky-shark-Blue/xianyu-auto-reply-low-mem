# ===== 27 Windows backend-web 环境变量模板 =====
# 复制为 backend-web\.env 后填入实际值（与 103 保持一致的凭据 + JWT）
# 该服务只处理商品搜索与扫码登录，通过 nginx 分流从 103 转发而来

ENVIRONMENT=production
LOG_LEVEL=INFO

# --- MySQL（通过本机 stunnel 桥接到 TiDB Cloud） ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=<TIDB_USER>
MYSQL_PASSWORD=<TIDB_PASSWORD>
MYSQL_DATABASE=xianyu_data

# --- Redis（通过本机 stunnel 桥接到 Upstash） ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=<UPSTASH_PASSWORD>
REDIS_DB=0

# --- JWT（必须与 103 完全一致，token 才互通） ---
JWT_SECRET_KEY=<SHARED_JWT_SECRET>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- 服务端口 ---
BACKEND_WEB_PORT=8089

# --- 服务间通信：指向 103 ---
# 27 本机不跑 websocket / scheduler，此处指向 103
WEBSOCKET_SERVICE_URL=http://192.168.1.103:8090
SCHEDULER_SERVICE_URL=http://192.168.1.103:8091

# --- 业务开关 ---
# 27 也不自动启动爬虫，避免 27 开机即被触发
AUTO_START_CRAWL_JOBS=false

# --- CORS ---
CORS_ORIGINS=*

# --- 静态资源（Windows 本地路径） ---
STATIC_DIR=static
FRONTEND_PUBLIC_URL=http://192.168.1.103:9000
BACKEND_WEB_PUBLIC_URL=http://192.168.1.103:9000
